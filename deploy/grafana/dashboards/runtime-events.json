{
  "title": "runtime-detect — Falco events",
  "uid": "runtime-detect-falco",
  "tags": ["runtime-detect", "falco", "security"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({app=\"falco\"}, k8s_ns_name)",
        "refresh": 2,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "priority",
        "type": "custom",
        "query": "Critical,Warning,Notice,Informational,Debug",
        "current": { "text": ["Critical","Warning"], "value": ["Critical","Warning"] },
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Critical events (last 30m)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"falco\", priority=\"Critical\"} [30m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warning events (last 30m)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "sum(count_over_time({app=\"falco\", priority=\"Warning\"} [30m]))", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Events / sec (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "sum(rate({app=\"falco\"} [5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Distinct rules fired",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "count(count by (rule) ({app=\"falco\"} [30m]))", "refId": "A" }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Events by severity over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (priority) (rate({app=\"falco\"} [1m]))",
          "refId": "A",
          "legendFormat": "{{priority}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Top rules (30m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (rule) (count_over_time({app=\"falco\", priority=~\"$priority\"} [30m])))",
          "refId": "A",
          "legendFormat": "{{rule}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "logs",
      "title": "Recent CRITICAL events",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{app=\"falco\", priority=\"Critical\"} |= \"\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
